# Example TLS reverse proxy to the OpenF1 query API on localhost:8000.
# Replace server_name and ssl_certificate paths; point UnderReview OPENF1_BASE_URL to https://<server_name>/v1

server {
	listen 443 ssl http2;
	server_name openf1.yourdomain.com;

	ssl_certificate     /etc/letsencrypt/live/openf1.yourdomain.com/fullchain.pem;
	ssl_certificate_key /etc/letsencrypt/live/openf1.yourdomain.com/privkey.pem;

	location / {
		proxy_pass http://127.0.0.1:8000;
		proxy_http_version 1.1;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
	}
}
