# Copy to .env for local dev (Vite + dev API). Set the same in Vercel for production.

# --- UR TAKE hardening ---
# Client (Vite): optional; shows client-side `/api/ur-take` failure JSON under the bubble when set to 1.
# VITE_UR_TAKE_CLIENT_DEBUG=1

# Require Authorization bearer on /api/ur-take and /api/performance (recommended in production).
# Set to false only for local debugging without tokens.
# UR_TAKE_REQUIRE_AUTH=false

# --- Structured UR Take (dual-publish JSON alongside prose) ---
# Chat sends structured:true + header X-UR-Take-Structured: 1; API enables structured JSON unless killed below.
# STRUCTURED_UR_TAKE_MODE=0   # emergency off (omit or any other value = structured allowed)
# Optional legacy gate (not required for chat): STRUCTURED_UR_TAKE_MODE=1
# No VITE_/REACT_APP_ flag required — UI renders URTakeResponse whenever the API returns `structured`.

# --- Core AI (UR TAKE) ---
ANTHROPIC_API_KEY=
# Optional; default in code is a current Sonnet class model
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Access + Pro (HMAC token secret; REQUIRED on Vercel Production — without it, access codes and UR TAKE auth fail) ---
# Generate e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=
# Optional alternate name (same value) if you already use this in Vercel:
# UR_ACCESS_TOKEN_SECRET=
OWNER_CODE=
# FRIEND_CODES=code1:2026-12-31,code2:2026-12-31

# --- Clerk (optional; when enabled, Pro refresh uses ur_access_token + email on /api/pro-status) ---
CLERK_SECRET_KEY=
# Client (Vite): required for sign-in + Pro flows
# VITE_CLERK_PUBLISHABLE_KEY=

# --- Stripe (checkout, pro-status, webhooks) ---
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- Pro magic link (Resend) — APP_BASE_URL used in checkout success_url and email links ---
RESEND_API_KEY=
AUTH_EMAIL_FROM=
APP_BASE_URL=https://under-review.app
# Pro status anti-enumeration: max GET /api/pro-status per IP per 60s (default 3). Raise if checkout sync hits limit.
# PRO_STATUS_RATE_IP_PER_MIN=3

# --- Durable store (Vercel KV) — optional; in-memory fallback if unset locally ---
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# (Also supports VERCEL_KV_* names in _durableStore.js)

# --- Vercel Cron — NBA home board prewarm (/api/nba?view=board&warmup=1) ---
# When set in Vercel project env, warmup requests must send Authorization: Bearer <CRON_SECRET>.
# Vercel Cron forwards CRON_SECRET automatically on scheduled invokes.
# Leave unset locally unless testing warmup auth.
# CRON_SECRET=
#
# After deploy during PGA Championship week, warm odds KV once (home outright card reads cache only):
#   WARM_BASE_URL=https://under-review.app CRON_SECRET=... npm run warm:golf-odds

# --- F1 (OpenF1-compatible API) ---
# Default is public https://api.openf1.org/v1. Point to your self-hosted fork (e.g. UR-Take-F1 / br-g/openf1) after deploy:
# OPENF1_BASE_URL=https://your-openf1.example.com/v1
# Alternate env name:
# UR_OPENF1_BASE_URL=https://your-openf1.example.com/v1
# If the backend requires auth (or official OpenF1 during restricted windows), use one of:
# OPENF1_AUTHORIZATION=Bearer your-token
# OPENF1_API_KEY=your-token-or-full-Authorization-value
# Self-hosted OpenF1 (query_api): set OPENF1_QUERY_API_KEY on the OpenF1 container to the exact same string as OPENF1_AUTHORIZATION (see openf1/UNDERREVIEW.md in this repo layout).

# --- Sports / odds data ---
ODDS_API_KEY=
# Multi-book match panel (tennis detail). WC cards use ESPN only — no per-card Odds API.
# Set 0 to disable /api/match-book-odds upstream calls entirely.
# MATCH_BOOK_ODDS=1
# NBA + ATP tennis + MLB slate/props/totals/injuries (tiered — MLB requires GOAT/ALL-STAR per balldontlie.io).
BALLDONTLIE_API_KEY=

# --- Same-day tennis news (overrides file-based default in api/tennis-context.js) ---
# Use "YYYY-MM-DD | short description" and clear when stale
# TENNIS_BREAKING=

# --- Same-day World Cup news (overrides file-based default in api/_wcUrTakeContext.js) ---
# Use "YYYY-MM-DD | short description" and clear when stale
# WC_BREAKING=
# Or POST /api/world-cup?view=player_markets_override with CRON_SECRET (KV beats env)

# --- World Cup player markets book scrape ---
# US books (DK/FD/MGM) default ON when env unset. FanDuel uses Research article URL (not SPA shell).
# UK books (Paddy/Bet365/William Hill): default ON in Vercel production (VERCEL_ENV=production).
#   Set WC_SCRAPE_UK=0 to disable UK scrapes in prod. Local dev: set WC_SCRAPE_UK=1 to test UK books.
# Aggregators (OddsChecker/Covers/VegasInsider): default ON in Vercel production.
# Media/editorial (Action Network, VSiN, Sky Sports, etc.): default ON in Vercel production.
# Set WC_SCRAPE_AGG=0 or WC_SCRAPE_MEDIA=0 to disable in prod.
# WC_SCRAPE_DK=1
# WC_SCRAPE_FD=1
# WC_SCRAPE_MGM=1
# WC_SCRAPE_UK=1
# WC_SCRAPE_AGG=0
# Aggregator / editorial URL overrides (optional):
# WC_SCRAPE_COVERS_URL=https://www.covers.com/world-cup
# WC_SCRAPE_ODDSSHARK_URL=https://www.oddsshark.com/soccer/world-cup/odds-to-win-2026
# WC_SCRAPE_ODDSCHECKER_URL=https://www.oddschecker.com/us/soccer/world-cup
# Golden Boot URL overrides (optional):
# WC_SCRAPE_FD_URL=https://www.fanduel.com/research/world-cup-golden-boot-betting-explained
# WC_SCRAPE_DK_URL=https://sportsbook.draftkings.com/leagues/soccer/world-cup-2026?category=goalscorer&subcategory=top-goalscorer
# Per-fixture match prop URLs (optional — defaults in shared/wcBookScrapePolicy.js):
# WC_SCRAPE_DK_MATCH_URL_TEMPLATE=https://sportsbook.draftkings.com/event/{eventId}
# WC_SCRAPE_FD_MATCH_URL_TEMPLATE=https://sportsbook.fanduel.com/soccer/fifa-world-cup-2026/{home}-v-{away}
# WC_SCRAPE_MGM_MATCH_URL_TEMPLATE=https://sports.betmgm.com/en/sports/events/{eventId}

# --- World Cup post-match chance quality (Phase 2) ---
# FBref Opta xG was removed Jan 2026. Post-FT chance indexes are derived from ESPN
# match detail (wc2026_match_advanced_stats KV) — not Opta xG. No env vars required.

# --- World Cup API-Football backup (Phase 3 — free tier 100 req/day) ---
# Register at https://www.api-football.com/ — same key works as API_SPORTS_KEY.
# API_FOOTBALL_KEY=
# WC_API_FOOTBALL=1

# --- World Cup live chance index (Phase 4) ---
# In-match ESPN-derived chance index in MATCH INTEL — not Opta xG. No env vars required.

# --- CORS (extra allowed origins, comma-separated) ---
# ALLOWED_ORIGINS=https://localhost:3000

# --- Local dev API server (dev-api-server.mjs) ---
# API_PORT=3001
