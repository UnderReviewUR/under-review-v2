{
  "name": "under-review-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node dev-api-server.mjs",
    "dev:local": "concurrently \"npm:dev\" \"npm:dev:api\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src api scripts",
    "test": "node --test api/_hmacToken.test.js api/_sanitizeUrTakeBody.test.js api/_gateQuota.test.js api/nfl-draft-season.test.js api/nfl-draft-engine.test.js src/lib/detectSportFromQuestion.test.js src/features/home/buildHomeTrackerCards.test.js src/features/home/buildDynamicHomeQuestions.test.js",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"api/**/*.js\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx}\" \"api/**/*.js\"",
    "refresh:tennis-form": "node refresh-tennis-form.mjs"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "vite": "^4.4.0",
    "xlsx": "^0.18.5"
  }
}
