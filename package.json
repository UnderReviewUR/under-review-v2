{
  "name": "under-review-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node dev-api-server.mjs",
    "dev:local": "concurrently \"npm:dev\" \"npm:dev:api\"",
    "build": "vite build",
    "preview": "vite preview",
    "check:api": "node scripts/check-api-syntax.mjs",
    "lint": "eslint src api scripts",
    "test": "node scripts/run-all-tests.mjs",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"api/**/*.js\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx}\" \"api/**/*.js\"",
    "refresh:tennis-form": "node refresh-tennis-form.mjs",
    "audit:stripe-dupes": "node scripts/stripe-duplicate-audit.mjs",
    "odds-usage-smoke": "node scripts/odds-api-usage-smoke.mjs",
    "warm:golf-odds": "node scripts/warm-golf-odds-cache.mjs",
    "warm:nba-props": "node scripts/warm-nba-props-cache.mjs",
    "warm:f1-odds": "node scripts/warm-f1-odds-cache.mjs --direct"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.4",
    "@clerk/clerk-react": "^5.61.6",
    "@vercel/analytics": "^2.0.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stripe": "^14.0.0"
  },
  "optionalDependencies": {
    "@sparticuz/chromium": "^133.0.0",
    "puppeteer-core": "^24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "vite": "^4.4.0",
    "xlsx": "^0.18.5"
  }
}
