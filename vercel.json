{
  "headers": [
    {
      "source": "/api/tennis",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    }
  ],
  "functions": {
    "api/ur-take.js": {
      "maxDuration": 60
    },
    "api/tennis.js": {
      "maxDuration": 45
    }
  },
  "crons": [
    {
      "path": "/api/nfl-depth-update",
      "schedule": "0 13 * * 0"
    },
    {
      "path": "/api/nfl-depth-update",
      "schedule": "0 14 * * 2"
    }
  ]
}
