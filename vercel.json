{
  "headers": [
    {
      "source": "/api/tennis",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    }
  ],
  "functions": {
    "api/ur-take.js": {
      "maxDuration": 60
    },
    "api/tennis.js": {
      "maxDuration": 45
    },
    "api/today-slate.js": {
      "maxDuration": 60
    },
    "api/nba.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/nfl-depth-update",
      "schedule": "0 13 * * 0"
    },
    {
      "path": "/api/nfl-depth-update",
      "schedule": "0 14 * * 2"
    },
    {
      "path": "/api/nfl-roster-refresh",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/nba?view=board&warmup=1",
      "schedule": "*/5 * * 1,2,3,4,5,6,10,11,12 *"
    }
  ]
}
