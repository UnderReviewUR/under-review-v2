{
  "rewrites": [
    {
      "source": "/worldcup",
      "destination": "/worldcup/index.html"
    },
    {
      "source": "/worldcup/",
      "destination": "/worldcup/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/tennis",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    }
  ],
  "functions": {
    "api/ur-take.js": {
      "maxDuration": 60
    },
    "api/tennis.js": {
      "maxDuration": 45
    },
    "api/today-slate.js": {
      "maxDuration": 60
    },
    "api/nba.js": {
      "maxDuration": 300
    },
    "api/daily-take.js": {
      "maxDuration": 120
    },
    "api/nfl-predict-share.js": {
      "maxDuration": 30
    },
    "api/golf-odds-scrape.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/nba-props-scrape.js": {
      "maxDuration": 60
    },
    "api/game-odds-refresh.js": {
      "maxDuration": 120
    },
    "api/scrape-scheduler.js": {
      "maxDuration": 300
    },
    "api/world-cup.js": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/nfl-depth-update",
      "schedule": "0 13 * * 0"
    },
    {
      "path": "/api/nfl-depth-update",
      "schedule": "0 14 * * 2"
    },
    {
      "path": "/api/nfl-roster-refresh",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/nba?view=board&warmup=1",
      "schedule": "*/5 * * 1,2,3,4,5,6,10,11,12 *"
    },
    {
      "path": "/api/daily-take?refresh=1",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/scrape-scheduler",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/world-cup?view=warmup&kind=all",
      "schedule": "0 15,23 * * *"
    }
  ]
}
